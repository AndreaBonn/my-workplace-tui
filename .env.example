# Google OAuth2
# Path al client secret scaricato da Google Cloud Console
GOOGLE_CLIENT_SECRET_PATH=credentials/client_secret.json
# Path al token OAuth2 (auto-generato al primo login)
GOOGLE_TOKEN_PATH=credentials/token.json

# Gmail
# Intervallo polling in secondi
GMAIL_POLL_INTERVAL=60
# Email per pagina
GMAIL_MAX_RESULTS=50

# Google Chat
# Intervallo polling in secondi
CHAT_POLL_INTERVAL=30

# Google Calendar
# Intervallo polling in secondi
CALENDAR_POLL_INTERVAL=300

# Notifiche desktop Ubuntu (true/false)
NOTIFICATIONS_ENABLED=true

# Cache locale (true/false)
CACHE_ENABLED=true
# TTL cache default in secondi
CACHE_TTL=300

# ──────────────────────────────────────────────────────────
# Jira (opzionale — lascia vuoto per disabilitare la tab Jira)
# ──────────────────────────────────────────────────────────

# Credenziali Atlassian (condivise tra tutti gli account)
# Email dell'account Atlassian
JIRA_USERNAME=
# API Token generato su https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Intervallo polling in secondi
JIRA_POLL_INTERVAL=120
# Issue per pagina
JIRA_MAX_RESULTS=50
# Consenti HTTP (solo per dev locale, default false)
# JIRA_ALLOW_HTTP=false

# --- Modalità SINGOLO account (legacy) ---
# Se usi un solo Jira, configura queste variabili:
# JIRA_BASE_URL=https://nomeazienda.atlassian.net
# JIRA_DEFAULT_PROJECT=PROJ

# --- Modalità MULTI-account ---
# Nomi account separati da virgola. Se impostato, le variabili
# JIRA_BASE_URL e JIRA_DEFAULT_PROJECT vengono ignorate.
# JIRA_ACCOUNTS=linkalab,marzocco
#
# Per ogni account, definisci:
#   JIRA_{NOME_MAIUSCOLO}_BASE_URL
#   JIRA_{NOME_MAIUSCOLO}_DEFAULT_PROJECT (opzionale)
#
# Esempio:
# JIRA_LINKALAB_BASE_URL=https://linkalab.atlassian.net
# JIRA_LINKALAB_DEFAULT_PROJECT=LL
# JIRA_MARZOCCO_BASE_URL=https://marzocco.atlassian.net
# JIRA_MARZOCCO_DEFAULT_PROJECT=LM

# Filtri JQL salvati (accessibili con F1-F9, globali per tutti gli account)
# JIRA_SAVED_JQL_1=assignee = currentUser() AND status != Done
# JIRA_SAVED_JQL_2=project = PROJ AND sprint in openSprints()

# Google Drive
# Dominio del workspace (es. azienda.com) — usato per distinguere
# file condivisi interni vs esterni nell'interfaccia Drive
WORKSPACE_DOMAIN=

# Directory di download per i file da Google Drive (supporta ~)
DRIVE_DOWNLOAD_DIR=~/Scaricati

# Mail Google con cui aprire i link
GOOGLE_ACCOUNT_EMAIL=tua.email@tua.azienda.it
