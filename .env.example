# Google OAuth2
# Path al client secret scaricato da Google Cloud Console
GOOGLE_CLIENT_SECRET_PATH=credentials/client_secret.json
# Path al token OAuth2 (auto-generato al primo login)
GOOGLE_TOKEN_PATH=credentials/token.json

# Gmail
# Intervallo polling in secondi
GMAIL_POLL_INTERVAL=60
# Email per pagina
GMAIL_MAX_RESULTS=50

# Google Chat
# Intervallo polling in secondi
CHAT_POLL_INTERVAL=30

# Google Calendar
# Intervallo polling in secondi
CALENDAR_POLL_INTERVAL=300

# Notifiche desktop Ubuntu (true/false)
NOTIFICATIONS_ENABLED=true

# Cache locale (true/false)
CACHE_ENABLED=true
# TTL cache default in secondi
CACHE_TTL=300

# Jira (opzionale — lascia vuoto per disabilitare la tab Jira)
# Email dell'account Atlassian
JIRA_USERNAME=
# API Token generato su https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=
# URL base istanza Jira (es. https://nomeazienda.atlassian.net)
JIRA_BASE_URL=
# Chiave progetto di default (es. PROJ)
JIRA_DEFAULT_PROJECT=
# Account ID Jira dell'utente (per filtrare "assegnati a me")
JIRA_ACCOUNT_ID=
# Intervallo polling in secondi
JIRA_POLL_INTERVAL=120
# Issue per pagina
JIRA_MAX_RESULTS=50

# Filtri JQL salvati (accessibili con F1, F2, ecc.)
# JIRA_SAVED_JQL_1=assignee = currentUser() AND status != Done
# JIRA_SAVED_JQL_2=project = PROJ AND sprint in openSprints()
